# === n8n Instance ============================================================
# Base URL of your n8n instance. All webhook calls use this as the base URL.
# Falls back to http://localhost:5678 (default n8n port) for local development.
VITE_API_BASE_URL=https://your-n8n-instance.com

# === Webhook paths (optional overrides) =====================================
# The app uses these default paths:
#   Upload:  /webhook/web-invoice-upload
#   History: /webhook/get-invoices
#
# Set the variables below ONLY if you need full-URL overrides (e.g. different
# domains per webhook, or webhook-test URLs for debugging).
# Use /webhook/ (production), NOT /webhook-test/ unless you're watching the
# n8n editor — the test URL fires only once per click.

# VITE_API_UPLOAD_URL=https://your-n8n-instance.com/webhook/web-invoice-upload
# VITE_API_INVOICES_URL=https://your-n8n-instance.com/webhook/get-invoices
