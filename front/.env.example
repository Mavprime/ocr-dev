# Full URLs of your n8n webhooks. Use /webhook/ (production), NOT /webhook-test/
# (the test URL only fires once while you click "Listen for test event" in the editor).
# Both workflows must be ACTIVE in n8n.

# Synchronous upload endpoint — returns the extracted invoice in the response.
VITE_API_UPLOAD_URL=https://your-n8n-instance.com/webhook/web-invoice-upload

# Invoice history endpoint — returns the 15 most recent rows from Google Sheets.
VITE_API_INVOICES_URL=https://your-n8n-instance.com/webhook/get-invoices
