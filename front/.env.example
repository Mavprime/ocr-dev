# === n8n Webhook Base URL ===================================================
# All webhook calls use this as the base URL.
#
# Webhook trigger paths (appended automatically by the app):
#   Upload:  web-invoice-upload
#   History: get-invoices
#
# --- Local Development ---
# Copy this to .env.development:
#   VITE_API_URL=https://n8n-local.magnetai.cc/webhook/
#
# --- Production ---
# Copy this to .env.production:
#   VITE_API_URL=https://n8n.magnetai.cc/webhook/
#
# Falls back to http://localhost:5678/webhook/ if VITE_API_URL is not set.

VITE_API_URL=https://your-n8n-instance.com/webhook/
